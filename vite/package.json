{
  "name": "wp-magick-toolbox-frontend",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev:admin": "pnpm --filter admin dev",
    "dev:public": "pnpm --filter public dev",
    "dev:count": "pnpm --filter count dev",
    "build:admin": "pnpm --filter admin build",
    "build:public": "pnpm --filter public build",
    "build:count": "pnpm --filter count build",
    "build": "pnpm -r build",
    "lint:admin": "pnpm --filter admin lint",
    "lint:public": "pnpm --filter public lint",
    "lint:count": "pnpm --filter count lint",
    "lint": "pnpm -r lint",
    "test:admin": "pnpm --filter admin test:run",
    "test": "pnpm --filter admin test:run",
    "test:coverage": "pnpm --filter admin test:coverage"
  },
  "engines": {
    "node": ">=18.12.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
