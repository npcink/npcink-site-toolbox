{
  "name": "wp-magick-toolbox-frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev:admin": "vite admin --config admin/vite.config.ts",
    "dev:count": "vite count --config count/vite.config.ts",
    "typecheck:admin": "tsc -p admin/tsconfig.json --noEmit",
    "typecheck:count": "tsc -p count/tsconfig.json --noEmit",
    "typecheck": "pnpm run typecheck:admin && pnpm run typecheck:count",
    "build:admin": "pnpm run typecheck:admin && vite build admin --config admin/vite.config.ts && node admin/src/check-admin-css-isolation.mjs && node admin/src/check-admin-build-contract.mjs",
    "build:count": "pnpm run typecheck:count && vite build count --config count/vite.config.ts && node count/src/check-count-build-contract.mjs",
    "build": "pnpm run build:admin && pnpm run build:count",
    "lint:admin": "eslint admin --ext ts,tsx --report-unused-disable-directives",
    "lint:count": "eslint count --ext ts,tsx --report-unused-disable-directives",
    "lint": "pnpm run lint:admin && pnpm run lint:count",
    "test:admin": "vitest run --root admin",
    "test": "pnpm run test:admin",
    "test:coverage": "vitest run --root admin --coverage --maxWorkers=1 --minWorkers=1",
    "preview:admin": "vite preview admin --config admin/vite.config.ts",
    "preview:count": "vite preview count --config count/vite.config.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "antd": "^5.10.0",
    "axios": "^1.4.0",
    "dayjs": "^1.11.21",
    "echarts": "^5.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/node": "^20.4.7",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.3",
    "@vitest/coverage-v8": "^1.0.4",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "jsdom": "^23.0.1",
    "typescript": "^5.0.2",
    "vite": "^4.4.5",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=18.12.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
